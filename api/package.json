    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "ms": "2.1.3",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "prisma": "7.6.0",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
